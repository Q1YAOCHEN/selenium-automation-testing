<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="INFO6255 Selenium Test Suite" verbose="1">

    <!-- Listener to generate HTML report after all tests -->
    <listeners>
        <listener class-name="tests.TestSuiteRunner"/>
    </listeners>

    <!-- All scenarios share one browser session -->
    <test name="NEU Selenium Test Scenarios">
        <classes>
            <class name="tests.Scenario1_DownloadTranscript"/>
            <class name="tests.Scenario2_AddCalendarEvents"/>
            <class name="tests.Scenario3_ReserveLibrary"/>
            <class name="tests.Scenario4_DownloadDataset"/>
            <class name="tests.Scenario5_UpdateAcademicCalendar"/>
        </classes>
    </test>

</suite>